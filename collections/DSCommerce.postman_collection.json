              "listen": "test",
              "script": {
                "exec": [
                  "if (responseCode.code >= 200 && responseCode.code < 300) {\r",
                  "var json = JSON.parse(responseBody);\r",
                  "postman.setEnvironmentVariable('token', json.access_token);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{client-id}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{client-secret}}",
                  "type": "string"
                },
                {
                  "key": "showPassword",
                  "value": false,
                  "type": "boolean"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "{{username}}",
                  "type": "text"
                },
                {
